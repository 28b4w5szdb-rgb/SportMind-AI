rules_version = '2';

/**
 * SportMind AI — Firestore Security Rules (Phase 6C.10 / 6C.11)
 *
 * Multi-tenant isolation, RBAC, clinical protection, research de-identification.
 * Custom claims preferred; org membership document resolves roles + direct permissions.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function claimOrgIds() {
      let ids = request.auth.token.get('organizationIds', []);
      return ids is list ? ids : [];
    }

    function claimPermissions() {
      let perms = request.auth.token.get('permissions', []);
      return perms is list ? perms : [];
    }

    function activeOrganizationId() {
      let activeOrg = request.auth.token.get('activeOrganizationId', '');
      return activeOrg is string ? activeOrg : '';
    }

    function isOrgAdminClaim() {
      return request.auth.token.get('isOrgAdmin', false) == true;
    }

    function memberPath(orgId) {
      return /databases/$(database)/documents/organizations/$(orgId)/users/$(uid());
    }

    function membershipDocActive(orgId) {
      return exists(memberPath(orgId)) &&
        get(memberPath(orgId)).data.get('status', '') == 'active';
    }

    function memberData(orgId) {
      return get(memberPath(orgId)).data;
    }

    function memberRoleIds(orgId) {
      let roles = memberData(orgId).get('role_ids', []);
      return roles is list ? roles : [];
    }

    function memberDirectPermissions(orgId) {
      let perms = memberData(orgId).get('permissions', []);
      return perms is list ? perms : [];
    }

    function isOrgMember(orgId) {
      return isSignedIn() && (
        activeOrganizationId() == orgId ||
        orgId in claimOrgIds()
      );
    }

    function isActiveOrgMember(orgId) {
      return isSignedIn() && (
        membershipDocActive(orgId) ||
        activeOrganizationId() == orgId ||
        orgId in claimOrgIds()
      );
    }

    function rolesGrantPermission(roleIds, permission) {
      return ('org_admin' in roleIds) ||
        (('coach' in roleIds || 'head_coach' in roleIds) &&
          permission in ['read_athletes', 'write_athletes', 'read_assessments', 'write_assessments']) ||
        ('head_coach' in roleIds &&
          permission in ['read_reports', 'write_reports']) ||
        (('physiotherapist' in roleIds || 'team_doctor' in roleIds) &&
          permission in ['read_athletes', 'read_assessments', 'read_medical', 'write_medical']) ||
        ('team_doctor' in roleIds && permission == 'read_reports') ||
        ('sports_scientist' in roleIds &&
          permission in ['read_athletes', 'read_assessments', 'write_assessments', 'read_research', 'read_reports']) ||
        ('researcher' in roleIds &&
          permission in ['read_research', 'export_research']) ||
        ('analyst' in roleIds &&
          permission in ['read_athletes', 'read_assessments', 'read_reports']) ||
        ('viewer' in roleIds &&
          permission in ['read_athletes', 'read_assessments']) ||
        ('athlete_portal' in roleIds && permission == 'read_assessments');
    }

    function membershipFlagsGrantPermission(orgId, permission) {
      let data = memberData(orgId);
      return (data.get('clinical_access', false) == true &&
          permission in ['read_medical', 'write_medical']) ||
        (data.get('research_access', false) == true && permission == 'read_research') ||
        (data.get('export_research', false) == true && permission == 'export_research');
    }

    function membershipGrantsPermission(orgId, permission) {
      return membershipDocActive(orgId) && (
        permission in memberDirectPermissions(orgId) ||
        membershipFlagsGrantPermission(orgId, permission) ||
        rolesGrantPermission(memberRoleIds(orgId), permission)
      );
    }

    function hasPermission(orgId, permission) {
      return isSignedIn() && (
        isOrgAdminClaim() ||
        permission in claimPermissions() ||
        membershipGrantsPermission(orgId, permission)
      );
    }

    function hasClinicalRead(orgId) {
      return hasPermission(orgId, 'read_medical');
    }

    function hasClinicalWrite(orgId) {
      return hasPermission(orgId, 'write_medical');
    }

    function immutableCreateOnly() {
      return request.resource.data.keys().hasAll(['created_at']) &&
        !resource.exists;
    }

    function sessionImmutableUpdate() {
      return false;
    }

    // ─── Global user profiles ───────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isSignedIn() && uid() == userId;
      allow create: if isSignedIn() && uid() == userId;
      allow update: if isSignedIn() && uid() == userId;
      allow delete: if false;
    }

    // ─── Global catalog (read-only for clients) ─────────────────────────────

    match /catalog_sports/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /catalog_assessment_categories/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /catalog_assessment_definitions/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /catalog_evidence_tiers/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /catalog_formulas/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /catalog_formulas/{formulaId}/versions/{versionId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /catalog_equipment_types/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /catalog_equipment_models/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /catalog_normative_references/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /catalog_normative_references/{refId}/versions/{versionId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /catalog_questionnaire_templates/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /catalog_assessment_definitions/{defId}/protocol_versions/{versionId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ─── Organization tenant root ───────────────────────────────────────────

    match /organizations/{orgId} {
      allow read: if isActiveOrgMember(orgId);
      allow create: if isSignedIn() && (isOrgAdminClaim() || 'manage_org' in claimPermissions());
      allow update: if isActiveOrgMember(orgId) && (isOrgAdminClaim() || hasPermission(orgId, 'manage_org'));
      allow delete: if false;

      // Org members / RBAC — self-read avoids get() recursion in membershipGrantsPermission()
      match /users/{memberId} {
        allow read: if isSignedIn() && (
          uid() == memberId ||
          (isActiveOrgMember(orgId) && (isOrgAdminClaim() || hasPermission(orgId, 'manage_users')))
        );
        allow create, update: if isActiveOrgMember(orgId) && (isOrgAdminClaim() || hasPermission(orgId, 'manage_users'));
        allow delete: if isActiveOrgMember(orgId) && isOrgAdminClaim();
      }

      match /role_definitions/{roleId} {
        allow read: if isActiveOrgMember(orgId);
        allow write: if isActiveOrgMember(orgId) && (isOrgAdminClaim() || hasPermission(orgId, 'manage_org'));
      }

      // Teams
      match /teams/{teamId} {
        allow read: if isActiveOrgMember(orgId) && hasPermission(orgId, 'read_athletes');
        allow create, update: if isActiveOrgMember(orgId) && hasPermission(orgId, 'write_athletes');
        allow delete: if isActiveOrgMember(orgId) && (isOrgAdminClaim() || hasPermission(orgId, 'manage_org'));

        match /memberships/{membershipId} {
          allow read: if isActiveOrgMember(orgId) && hasPermission(orgId, 'read_athletes');
          allow create, update: if isActiveOrgMember(orgId) && hasPermission(orgId, 'write_athletes');
          allow delete: if isActiveOrgMember(orgId) && (isOrgAdminClaim() || hasPermission(orgId, 'manage_org'));
        }
      }

      // Athletes — coaches read/write; no embedded diagnosis fields on write from non-clinical roles
      match /athletes/{athleteId} {
        allow read: if isActiveOrgMember(orgId) && hasPermission(orgId, 'read_athletes');
        allow create, update: if isActiveOrgMember(orgId) && hasPermission(orgId, 'write_athletes') &&
          (!request.resource.data.keys().hasAny(['diagnosis', 'clinical_notes', 'treatment_plan']) ||
            hasClinicalWrite(orgId));
        allow delete: if isActiveOrgMember(orgId) && isOrgAdminClaim();
      }

      // Equipment
      match /equipment/{equipmentId} {
        allow read: if isActiveOrgMember(orgId);
        allow create, update: if isActiveOrgMember(orgId) && hasPermission(orgId, 'manage_equipment');
        allow delete: if isActiveOrgMember(orgId) && (isOrgAdminClaim() || hasPermission(orgId, 'manage_equipment'));

        match /maintenance_logs/{logId} {
          allow read: if isActiveOrgMember(orgId);
          allow create, update: if isActiveOrgMember(orgId) && hasPermission(orgId, 'manage_equipment');
          allow delete: if false;
        }
      }

      // Locations
      match /locations/{locationId} {
        allow read: if isActiveOrgMember(orgId);
        allow create, update: if isActiveOrgMember(orgId) && (isOrgAdminClaim() || hasPermission(orgId, 'manage_org'));
        allow delete: if isActiveOrgMember(orgId) && isOrgAdminClaim();
      }

      match /seasons/{seasonId} {
        allow read: if isActiveOrgMember(orgId);
        allow write: if isActiveOrgMember(orgId) && (isOrgAdminClaim() || hasPermission(orgId, 'manage_org'));
      }

      match /sport_configs/{configId} {
        allow read: if isActiveOrgMember(orgId);
        allow write: if isActiveOrgMember(orgId) && (isOrgAdminClaim() || hasPermission(orgId, 'manage_org'));
      }

      // Medical records — clinical roles only (full diagnosis-level data)
      match /medical_records/{recordId} {
        allow read: if isActiveOrgMember(orgId) && hasClinicalRead(orgId);
        allow create, update: if isActiveOrgMember(orgId) && hasClinicalWrite(orgId);
        allow delete: if false;
      }

      // Research datasets — de-identified by default
      match /research_datasets/{datasetId} {
        allow read: if isActiveOrgMember(orgId) && hasPermission(orgId, 'read_research') &&
          resource != null && resource.data.get('deidentified', false) == true;
        allow create: if isActiveOrgMember(orgId) && hasPermission(orgId, 'export_research') &&
          request.resource.data.deidentified == true &&
          request.resource.data.keys().hasAll(['pseudonym_id', 'organization_id']);
        allow update, delete: if false;
      }

      // Org-scoped reports
      match /reports/{reportId} {
        allow read: if isActiveOrgMember(orgId) && hasPermission(orgId, 'read_reports');
        allow create, update: if isActiveOrgMember(orgId) && hasPermission(orgId, 'write_reports');
        allow delete: if isActiveOrgMember(orgId) && isOrgAdminClaim();

        // Role-filtered section views — clinical/research isolated from coach-safe main doc (Phase 8.1)
        match /role_views/{roleId} {
          allow read: if isActiveOrgMember(orgId) && (
            (roleId == 'coach' && hasPermission(orgId, 'read_reports')) ||
            (roleId == 'sports_scientist' && hasPermission(orgId, 'read_reports')) ||
            (roleId == 'clinical' && hasClinicalRead(orgId)) ||
            (roleId == 'research' && hasPermission(orgId, 'read_research'))
          );
          allow create, update: if isActiveOrgMember(orgId) && hasPermission(orgId, 'write_reports');
          allow delete: if false;
        }
      }

      // Append-only audit trail
      match /audit_logs/{eventId} {
        allow read: if isActiveOrgMember(orgId) && (isOrgAdminClaim() || hasPermission(orgId, 'manage_org'));
        allow create: if isActiveOrgMember(orgId);
        allow update, delete: if false;
      }

      // Assessment sessions — append-only scientific records
      match /assessment_sessions/{sessionId} {
        allow read: if isActiveOrgMember(orgId) && hasPermission(orgId, 'read_assessments');
        allow create: if isActiveOrgMember(orgId) && hasPermission(orgId, 'write_assessments') &&
          request.resource.data.organization_id == orgId;
        allow update, delete: if sessionImmutableUpdate();

        match /raw_measurements/{measurementId} {
          allow read: if isActiveOrgMember(orgId) && hasPermission(orgId, 'read_assessments');
          allow create: if isActiveOrgMember(orgId) && hasPermission(orgId, 'write_assessments');
          allow update, delete: if false;
        }

        match /calculated_metrics/{metricId} {
          allow read: if isActiveOrgMember(orgId) && hasPermission(orgId, 'read_assessments');
          allow create: if isActiveOrgMember(orgId) && hasPermission(orgId, 'write_assessments');
          allow update, delete: if false;
        }

        // normative_snapshot (canonical) — alias normative_snapshots blocked at rules level
        match /normative_snapshot/{snapshotId} {
          allow read: if isActiveOrgMember(orgId) && hasPermission(orgId, 'read_assessments');
          allow create: if isActiveOrgMember(orgId) && hasPermission(orgId, 'write_assessments');
          allow update, delete: if false;
        }

        // interpretations (SSID / scientific_interpretations canonical subcollection name)
        match /interpretations/{interpretationId} {
          allow read: if isActiveOrgMember(orgId) && hasPermission(orgId, 'read_assessments');
          allow create: if isActiveOrgMember(orgId) && hasPermission(orgId, 'write_assessments');
          allow update, delete: if false;
        }
      }
    }

    // ─── Legacy top-level collections (org_id field isolation) ──────────────

    match /reports/{reportId} {
      allow read: if isSignedIn() && hasPermission(resource.data.organization_id, 'read_reports') &&
        isActiveOrgMember(resource.data.organization_id);
      allow create, update: if isSignedIn() && hasPermission(request.resource.data.organization_id, 'write_reports') &&
        isActiveOrgMember(request.resource.data.organization_id);
      allow delete: if false;
    }

    match /injuries/{injuryId} {
      allow read: if isSignedIn() && hasClinicalRead(resource.data.organization_id) &&
        isActiveOrgMember(resource.data.organization_id);
      allow create, update: if isSignedIn() && hasClinicalWrite(request.resource.data.organization_id) &&
        isActiveOrgMember(request.resource.data.organization_id);
      allow delete: if false;
    }

    // Deny all other paths by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

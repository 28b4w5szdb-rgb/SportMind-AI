        "equipment": "Barbell, rack, spotters",
        "aiRec": "Align strength volume with readiness KPI; deload if fatigue exceeds target range."
      },
      "cooper": {
        "name": "Cooper Test",
        "description": "12-minute run for maximum distance.",
        "protocol": "Standardized track or treadmill. Distance recorded to nearest meter.",
        "equipment": "Track/treadmill, stopwatch",
        "aiRec": "Use result to calibrate endurance microcycles and recovery between high-volume weeks."
      },
      "yoyo": {
        "description": "Intermittent recovery test to exhaustion.",
        "protocol": "Yo-Yo IR1 audio protocol with 20m shuttle runs.",
        "equipment": "Cones, audio track",
        "aiRec": "Track trend across mesocycles; reduce HIIT density if fatigue KPI rises."
      },
      "beep": {
        "description": "Multi-stage shuttle run to estimate VO₂ max.",
        "protocol": "Standard beep test audio with 20m shuttles.",
        "equipment": "Cones, audio track",
        "aiRec": "Compare level against position norms before intensive tactical blocks."
      },
      "illinois": {
        "name": "Illinois Agility Test",
        "description": "Timed agility course with direction changes.",
        "protocol": "One practice + two timed trials. Best time recorded.",
        "equipment": "Cones, stopwatch",
        "aiRec": "Pair with COD drills if below team average; avoid high COD volume when injury risk elevated."
      },
      "cmj": {
        "description": "Vertical jump from countermovement without arm swing.",
        "protocol": "Three trials on force plate or jump mat. Best height used.",
        "equipment": "Jump mat or force plate",
        "aiRec": "Monitor CMJ trend as neuromuscular freshness marker before match weeks."
      },
      "sitReach": {
        "name": "Sit and Reach",
        "description": "Hamstring and lower-back flexibility assessment.",
        "protocol": "Three attempts; best reach distance recorded.",
        "equipment": "Sit-and-reach box",
        "aiRec": "Add targeted mobility if below reference and injury risk module is flagged."
      },
      "yBalance": {
        "name": "Y Balance Test",
        "description": "Composite reach score for dynamic balance.",
        "protocol": "Three reaches per direction; composite % of leg length calculated.",
        "equipment": "Y balance kit or tape markers",
        "aiRec": "Address asymmetry >4% with unilateral stability work before return-to-play progression."
      },
      "bodyFat": {
        "name": "Body Fat %",
        "description": "Skinfold or bioimpedance body fat estimate.",
        "protocol": "Standardized hydration and time-of-day. ISAK or device protocol followed.",
        "equipment": "Caliper or BIA device",
        "aiRec": "Integrate with nutrition planning; avoid aggressive deficits during heavy load phases."
      },
      "visualReaction": {
        "name": "Visual Reaction Test",
        "description": "Simple reaction time to visual stimulus.",
        "protocol": "10 trials after familiarization; median time recorded.",
        "equipment": "Reaction app or light system",
        "aiRec": "Low readiness plus slow reaction may indicate CNS fatigue — consider recovery day."
      },
      "cmjRsi": {
        "name": "CMJ RSI",
        "description": "Reactive strength index from countermovement jump.",
        "protocol": "Calculate RSI (jump height / contact time) from force plate trials.",
        "equipment": "Force plate",
        "aiRec": "RSI drop >10% vs baseline suggests neuromuscular fatigue — reduce plyometric volume."
      },
      "fms": {
        "name": "FMS Screening",
        "description": "Functional Movement Screen composite score.",

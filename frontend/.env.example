# SportMind AI — Frontend environment variables
# Copy to .env and fill in values. Never commit .env with real secrets.

# ─── Development ───────────────────────────────────────────────────────────────
# Bypass auth gate and launch into dashboard with a mock user.
EXPO_PUBLIC_DEV_BYPASS_AUTH=true

# Data source: mock (default) or cloud when Firebase is configured.
# Keep false for v0.9 alpha — app uses local mock store.
EXPO_PUBLIC_USE_CLOUD_DATA=false

# ─── Firebase (Phase 6A foundation — placeholders) ─────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
# Optional
# EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Supabase (legacy auth — optional during Firebase migration) ─────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Optional ──────────────────────────────────────────────────────────────────
# EXPO_PUBLIC_BACKEND_URL=http://localhost:8001
# EXPO_PUBLIC_OPENAI_API_KEY=

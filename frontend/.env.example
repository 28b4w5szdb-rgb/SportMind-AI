# SportMind AI — Frontend environment variables
# Copy to .env and fill in your Supabase project credentials.

# Development mock mode — bypass auth gate and launch into dashboard with a mock user.
# Set to false (or remove) to restore real Supabase authentication.
EXPO_PUBLIC_DEV_BYPASS_AUTH=true

# Supabase (required for auth and data when DEV_BYPASS_AUTH=false)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional — legacy FastAPI backend (not used in Supabase-first mode)
# EXPO_PUBLIC_BACKEND_URL=http://localhost:8001

# Optional — OpenAI for AI Coach (future phase)
# EXPO_PUBLIC_OPENAI_API_KEY=

{
  "expo": {
    "name": "SportMind AI",
    "slug": "sportmind-ai",
    "version": "0.9.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sportmind",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emergent.sportsanalytics.clj3mz"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0066FF"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.emergent.sportsanalytics.clj3mz"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "image": "./assets/images/splash-image.png",
            "backgroundColor": "#0F172A"
          }
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
